# --- Search service ---
MODEL_NAME=all-MiniLM-L6-v2
EMBED_DIM=384
DEFAULT_K=5
DEFAULT_NPROBE=64
PORT=8000
WORKERS=1

# --- Paths (must point inside the mounted volume) ---
FAISS_INDEX=/data/wiki_faiss.index
TITLES_FILE=/data/wiki_titles.txt
BUILD_MANIFEST=/data/build_manifest.json

# --- Index build ---
# Set to false to force a full rebuild from scratch
BUILD_RESUME=true
# Leave empty to use the latest Wikimedia title dump
WIKI_DUMP_URL=
BUILD_BATCH_SIZE=512       # Titles per embedding batch; higher = faster build, more RAM
# FAISS IVF cluster count for training; must be < sqrt(num_titles). Default 4096 works at Wikipedia scale.
BUILD_NLIST=4096
# Fraction of total titles used to train the IVF quantizer. Higher = better clusters but slower init. Must be ≤ 1.0.
BUILD_SAMPLE_FRAC=0.1
